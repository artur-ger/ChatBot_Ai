# Корневой env для запуска Docker Compose из корня репозитория.
# Скопируй в .env и поправь значения при необходимости.

# --- Embeddings ---
USE_FAKE_EMBEDDINGS=false
HF_TOKEN=

# --- Admin API (обязательно в prod) ---
# ADMIN_API_TOKEN=change-me-in-production
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me (используется для входа в /admin)
# ADMIN_SESSION_SECRET=  # секрет для подписи cookie сессии (генерируется init-env)
# LLM_SETTINGS_ENCRYPTION_KEY=  # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# LLM_ALLOW_RULE_BASED_FALLBACK=false
# LLM_BOOTSTRAP_DEFAULT=true

# --- Public UI ---
# Показывать ссылку «Админ-панель» на главной странице чата (false для prod)
PUBLIC_SHOW_ADMIN_LINK=false

# --- Chat ACL (для server-to-server интеграций; веб-чат обычно true = ACL выключен) ---
CHAT_ACL_DISABLED=true

# --- Telegram (профиль `telegram` в compose) ---
# TELEGRAM_BOT_TOKEN=
# BOT_ADMIN_API_TOKEN берётся из ADMIN_API_TOKEN автоматически в docker-compose

# --- Docker images (опционально) ---
# PYTHON_BASE_IMAGE=cr.yandex.net/<registry-id>/python:3.12-slim
# POSTGRES_IMAGE=cr.yandex.net/<registry-id>/postgres:15-alpine
# REDIS_IMAGE=cr.yandex.net/<registry-id>/redis:7-alpine
# CHROMA_IMAGE=cr.yandex.net/<registry-id>/chroma:1.5.8

# --- GigaChat: секреты (Basic OAuth) — только в /admin → LLM integrations ---
# Опционально для dev (TLS Sber): GIGACHAT_ALLOW_UNSAFE_TLS=true
# GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
# GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1
