APP_NAME=ChatBot AI Backend
API_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://chatbot:chatbot@localhost:5432/chatbot_ai

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_PATH=./data/chroma

UPLOAD_TEMP_DIR=./data/uploads
MAX_UPLOAD_BYTES=10485760

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_VERSION=all-MiniLM-L6-v2
USE_FAKE_EMBEDDINGS=false

CHUNK_SIZE=900
CHUNK_OVERLAP=120

RETRIEVER_TOP_K=5
MIN_CHUNK_SCORE=0.25
LLM_TIMEOUT_SECONDS=6
LLM_RETRY_ATTEMPTS=2
LLM_MODEL=rule-based-llm

CHAT_HISTORY_MAX_MESSAGES=12
CHAT_HISTORY_MAX_CHARS=6000

RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_CHAT=30/minute

OTEL_EXPORTER_OTLP_ENDPOINT=
