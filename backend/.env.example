# Скопируй в .env и при необходимости поправь значения.
# Удобный локальный режим: без подписи чата и без тяжёлых эмбеддингов.

DATABASE_URL=postgresql+asyncpg://chatbot:chatbot@localhost:5432/chatbot_ai
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Пустой CHROMA_HOST = локальный файл (см. CHROMA_PERSIST_PATH), без отдельного сервиса Chroma
CHROMA_HOST=
CHROMA_PERSIST_PATH=./data/chroma

# Docker compose по умолчанию качает модель с HF (USE_FAKE_EMBEDDINGS=false). Для офлайна: USE_FAKE_EMBEDDINGS=true
USE_FAKE_EMBEDDINGS=false

# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_MODEL_VERSION=all-MiniLM-L6-v2
# HF_TOKEN=hf_...         # gated-модели; compose подставляет HF_TOKEN из этого файла
# HF_HOME=./data/hf-cache # локально без Docker; в compose кеш — том huggingface_cache

# Локально true — не нужен заголовок X-Chat-Signature. В проде обязательно false.
CHAT_ACL_DISABLED=true
CHAT_ACL_SECRET=local-dev-chat-secret

# Telegram Bot API token от @BotFather
TELEGRAM_BOT_TOKEN=

# --- Только для docker compose: образы из своего registry в облаке (вместо Docker Hub) ---
# Один раз залей копии образов (см. README и scripts/push_mirror_images.ps1), затем раскомментируй:
# POSTGRES_IMAGE=cr.yandex.net/<registry-id>/postgres:15-alpine
# REDIS_IMAGE=cr.yandex.net/<registry-id>/redis:7-alpine
# CHROMA_IMAGE=cr.yandex.net/<registry-id>/chroma:1.5.8
